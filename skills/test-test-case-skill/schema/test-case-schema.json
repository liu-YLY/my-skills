{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["metadata", "test_cases"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["module", "feature", "owner", "last_reviewed"],
      "properties": {
        "module": {
          "type": "string",
          "description": "所属大模块"
        },
        "feature": {
          "type": "string",
          "description": "当前文件聚焦功能"
        },
        "owner": {
          "type": "string",
          "description": "负责人（英文名）"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date",
          "description": "最后评审日期（YYYY-MM-DD）"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "全局标签"
        }
      },
      "additionalProperties": false
    },
    "test_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "steps", "expected_results", "priority", "type"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TC_[A-Z0-9_]{3,}_[0-9]{3}$",
            "description": "全局唯一ID，格式 TC_<功能缩写>_<三位序号>"
          },
          "title": {
            "type": "string",
            "description": "简洁动词开头的标题"
          },
          "description": {
            "type": "string",
            "description": "补充说明（可选）"
          },
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2"],
            "description": "优先级"
          },
          "type": {
            "type": "string",
            "enum": ["functional", "ui", "security", "performance", "accessibility"],
            "description": "用例类型"
          },
          "preconditions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "执行前提（可选）"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "description": "操作步骤（每步一句话）"
          },
          "expected_results": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "description": "预期结果（可多条）"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "用例级标签"
          },
          "auto": {
            "type": "boolean",
            "default": false,
            "description": "是否计划自动化（默认 false）"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}